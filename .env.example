# ===========================================
# n8n Pipeline Environment Variables
# ===========================================
# These are ONLY needed if running n8n via docker-compose.
# If running n8n locally (n8n start), set these as n8n
# environment variables via Settings → Variables in the n8n UI,
# or as system environment variables.
#
# Stage 1 credentials come entirely from the request payload.
# Stage 2 uses these ONLY when connection_id=0 (internal Syntheta MySQL).

# MySQL / Syntheta Internal DB (used by Stage 2 when connection_id=0)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=welcome@123
MYSQL_DATABASE=syntheta_db
